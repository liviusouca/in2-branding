---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Divider from '../../components/Divider.astro';
import IconList from '../../components/IconList.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Icon from '../../components/Icon.astro';
import { useTranslations, locales, type Lang } from '../../i18n/utils';
import howImg from '../../assets/how-we-work.jpg';
import giftImg from '../../assets/gift-sets.jpg';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const stepIcons = ['user', 'box'];
const giftItems = t.giftSets.items.map((text, i) => ({ icon: ['diamond', 'gift', 'people', 'star'][i], text }));
---
<Layout lang={lang} route="how-we-work" title={t.seo.howWeWork.title} description={t.seo.howWeWork.description}>
  <!-- Page intro -->
  <section class="section section--cream pagehead">
    <div class="wrap text-center reveal">
      <p class="kicker">IN2 Branding</p>
      <h1 class="h-display">
        {t.howWeWork.title.split(' ')[0]}
        <span class="script">{t.howWeWork.title.split(' ').slice(1).join(' ')}</span>
      </h1>
      <Divider align="center" />
    </div>
  </section>

  <!-- Process steps -->
  <section class="section section--cream-2" style="padding-top:0">
    <div class="wrap work">
      <div class="work__text reveal">
        <ol class="steps">
          {t.howWeWork.steps.map((step, i) => (
            <li class="step">
              <span class="step__num">0{i + 1}</span>
              <span class="step__badge"><Icon name={stepIcons[i]} size={22} /></span>
              <div>
                <h2 class="step__title">{step.title}</h2>
                <p class="step__text">{step.text}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
      <div class="work__media reveal">
        <Image src={howImg} alt="Sketchbook with premium branding and packaging concepts" widths={[420, 720, 960]} sizes="(max-width: 950px) 90vw, 46vw" />
      </div>
    </div>
  </section>

  <!-- Gift Sets -->
  <section class="section section--dark gifts">
    <div class="wrap gifts__grid">
      <div class="gifts__media reveal">
        <Image src={giftImg} alt="Premium branded gift set with curated products" widths={[480, 820, 1100]} sizes="(max-width: 950px) 92vw, 50vw" />
      </div>
      <div class="gifts__text reveal">
        <h2 class="h-section">
          {t.giftSets.title.split(' ').slice(0, 2).join(' ')}<br />
          <span class="h-gold">{t.giftSets.title.split(' ').slice(2).join(' ')}</span>
        </h2>
        <Divider align="start" />
        <p class="lead">{t.giftSets.description}</p>
        <div class="gifts__list">
          <IconList items={giftItems} variant="stack" />
        </div>
        <p class="gifts__highlight">
          <Icon name="leaf" size={20} />
          <span>{t.giftSets.highlight}</span>
        </p>
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />
</Layout>

<style>
  .pagehead { padding-bottom: clamp(2rem, 4vw, 3rem); }

  .work { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: center; }
  .steps { list-style: none; margin: 0; padding: 0; display: grid; gap: 2.5rem; counter-reset: s; }
  .step { display: grid; grid-template-columns: auto auto 1fr; gap: 1.2rem; align-items: start; }
  .step__num { font-family: var(--serif); font-size: 2.4rem; color: var(--gold); line-height: 1; font-weight: 500; }
  .step__badge {
    width: 46px; height: 46px; border-radius: 50%; display: grid; place-items: center;
    border: 1px solid var(--line); color: var(--gold); background: rgba(255,255,255,0.4);
  }
  .step__title { font-family: var(--serif); font-size: 1.5rem; font-weight: 500; margin-bottom: 0.4rem; }
  .step__text { color: var(--ink-soft); margin: 0; }
  .work__media :global(img) { border-radius: var(--radius); box-shadow: 0 40px 60px -45px rgba(43,37,33,0.6); width: 100%; }

  .gifts__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: center; }
  .gifts__media :global(img) { border-radius: var(--radius); box-shadow: 0 44px 70px -40px rgba(0,0,0,0.75); width: 100%; }
  .gifts__list { margin-top: 1.8rem; }
  .gifts__highlight {
    display: flex; align-items: center; gap: 0.7rem; margin-top: 2rem;
    color: var(--gold-soft); font-weight: 500; font-size: 1.12rem; font-family: var(--serif); font-style: italic;
  }
  .gifts__highlight :global(svg) { color: var(--gold-soft); flex: none; }

  @media (max-width: 950px) {
    .work, .gifts__grid { grid-template-columns: 1fr; }
    .work__media, .gifts__media { order: -1; }
  }
</style>
