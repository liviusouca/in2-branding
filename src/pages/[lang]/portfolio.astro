---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Divider from '../../components/Divider.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { useTranslations, locales, type Lang } from '../../i18n/utils';
import ourWork from '../../assets/our-work.jpg';
import projects from '../../data/projects.json';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

// Project cover images synced from Sanity into src/assets/projects/.
const projImgs = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/projects/*.jpg',
  { eager: true }
);
const coverOf = (file: string) => projImgs[`../../assets/projects/${file}`]?.default;
type Proj = { image: string; featured: boolean; title: Record<string, string>; description: Record<string, string> };
const items = (projects as Proj[]).filter((p) => coverOf(p.image));
---
<Layout lang={lang} route="portfolio" title={t.seo.portfolio.title} description={t.seo.portfolio.description}>
  <section class="section section--cream pagehead">
    <div class="wrap text-center reveal">
      <p class="kicker">IN2 Branding</p>
      <h1 class="h-display">
        {t.ourWork.title.split(' ')[0]}
        <span class="h-gold">{t.ourWork.title.split(' ').slice(1).join(' ')}</span>
      </h1>
      <Divider align="center" />
      <p class="lead pagehead__lead">{t.ourWork.subtitle}</p>
    </div>
  </section>

  <section class="section section--cream" style="padding-top:0">
    <div class="wrap">
      <figure class="feature reveal">
        <Image src={ourWork} alt="IN2 Branding" widths={[720, 1100, 1440]} sizes="(max-width: 1200px) 92vw, 1200px" />
        <figcaption>{t.ourWork.intro}</figcaption>
      </figure>

      <div class="grid">
        {items.map((p) => (
          <figure class="tile reveal">
            <Image src={coverOf(p.image)!} alt={p.title[lang] || p.title.en} widths={[360, 560, 760]} sizes="(max-width: 700px) 92vw, 30vw" />
            {(p.title[lang] || p.title.en) && (
              <figcaption class="tile__cap">{p.title[lang] || p.title.en}</figcaption>
            )}
          </figure>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />
</Layout>

<style>
  .pagehead__lead { margin-inline: auto; text-align: center; margin-top: 0.6rem; }

  .feature { margin: 0 0 1.5rem; }
  .feature :global(img) { width: 100%; border-radius: var(--radius); box-shadow: 0 40px 70px -45px rgba(43,37,33,0.6); }
  .feature figcaption {
    margin-top: 1.2rem; text-align: center; color: var(--muted);
    font-family: var(--serif); font-style: italic; font-size: 1.2rem; max-width: 60ch; margin-inline: auto;
  }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; margin-top: 1.5rem; }
  .tile {
    margin: 0; overflow: hidden; border-radius: var(--radius);
    border: 1px solid var(--line-soft); background: var(--cream-2); position: relative;
  }
  .tile :global(img) { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; transition: transform 0.7s var(--ease); }
  .tile:hover :global(img) { transform: scale(1.05); }
  .tile__cap {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 1.6rem 1rem 0.8rem;
    background: linear-gradient(to top, rgba(23,19,16,0.72), transparent);
    color: #fff; font-family: var(--serif); font-size: 1.05rem; line-height: 1.25;
  }
  .grid .tile:first-child { grid-column: span 2; }

  @media (max-width: 760px) {
    .grid { grid-template-columns: 1fr 1fr; }
    .grid .tile:first-child { grid-column: span 2; }
  }
</style>
