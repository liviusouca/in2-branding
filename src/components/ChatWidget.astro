---
import { useTranslations, type Lang } from '../i18n/utils';
import kbPl from '../data/chat-pl.json';
import kbEn from '../data/chat-en.json';
import kbRo from '../data/chat-ro.json';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const kbByLang = { pl: kbPl, en: kbEn, ro: kbRo } as const;
const data = { ui: t.chat, kb: kbByLang[lang], lang };
---
<div class="chat" data-chat>
  <button class="chat__launcher" data-chat-open aria-expanded="false" aria-controls="in2-chat-panel">
    <span class="chat__launcher-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 5.5h16a1 1 0 0 1 1 1V16a1 1 0 0 1-1 1H9l-4 3.5V17H4a1 1 0 0 1-1-1V6.5a1 1 0 0 1 1-1z"/>
        <path d="M8 10h8M8 13h5"/>
      </svg>
    </span>
    <span class="chat__launcher-label">{t.chat.launcher}</span>
  </button>

  <section
    id="in2-chat-panel"
    class="chat__panel"
    data-chat-panel
    role="dialog"
    aria-modal="false"
    aria-label={t.chat.title}
    hidden
  >
    <header class="chat__head">
      <div class="chat__head-brand">
        <span class="chat__avatar" aria-hidden="true">IN2</span>
        <span class="chat__head-text">
          <strong>{t.chat.title}</strong>
          <small>{t.chat.status}</small>
        </span>
      </div>
      <button class="chat__close" data-chat-close aria-label={t.chat.close}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </header>

    <div class="chat__log" data-chat-log aria-live="polite" aria-atomic="false"></div>

    <div class="chat__suggestions" data-chat-suggestions></div>

    <form class="chat__form" data-chat-form>
      <input
        class="chat__input"
        data-chat-input
        type="text"
        autocomplete="off"
        placeholder={t.chat.placeholder}
        aria-label={t.chat.placeholder}
      />
      <button class="chat__send" type="submit" aria-label={t.chat.send}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h15M13 6l6 6-6 6"/></svg>
      </button>
    </form>
    <p class="chat__disclaimer">{t.chat.disclaimer}</p>
  </section>
</div>

<style>
  .chat { position: fixed; right: clamp(1rem, 3vw, 2rem); bottom: clamp(1rem, 3vw, 2rem); z-index: 200; font-family: var(--sans); }

  /* Launcher */
  .chat__launcher {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: linear-gradient(120deg, var(--gold-deep), var(--gold) 60%, var(--gold-soft));
    color: #fff; border: none; cursor: pointer;
    padding: 0.85rem 1.25rem; border-radius: 999px;
    box-shadow: 0 18px 34px -14px rgba(154, 123, 62, 0.7);
    font-size: 0.82rem; letter-spacing: 0.06em;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), opacity 0.25s var(--ease);
  }
  .chat__launcher:hover { transform: translateY(-2px); box-shadow: 0 22px 40px -14px rgba(154, 123, 62, 0.8); }
  .chat__launcher-icon { display: inline-flex; }
  .chat.is-open .chat__launcher { opacity: 0; pointer-events: none; transform: scale(0.9); }

  /* Panel */
  .chat__panel {
    position: absolute; right: 0; bottom: 0;
    width: min(92vw, 380px); height: min(72vh, 560px);
    display: flex; flex-direction: column;
    background: var(--cream); color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 40px 80px -30px rgba(43, 37, 33, 0.5);
    transform: translateY(16px) scale(0.98); opacity: 0;
    transition: transform 0.35s var(--ease), opacity 0.3s var(--ease);
  }
  .chat.is-open .chat__panel { transform: none; opacity: 1; }
  .chat__panel[hidden] { display: none; }

  .chat__head {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding: 0.9rem 1rem; color: var(--cream);
    background: radial-gradient(120% 160% at 15% 0%, var(--black-2), var(--black) 80%);
  }
  .chat__head-brand { display: flex; align-items: center; gap: 0.7rem; }
  .chat__avatar {
    width: 40px; height: 40px; flex: none; display: grid; place-items: center;
    border: 1px solid rgba(201, 168, 106, 0.5); border-radius: 50%;
    font-family: var(--serif); font-weight: 600; font-size: 0.95rem; color: var(--gold-soft);
    letter-spacing: 0.02em;
  }
  .chat__head-text { display: flex; flex-direction: column; line-height: 1.25; }
  .chat__head-text strong { font-family: var(--serif); font-weight: 500; font-size: 1.1rem; }
  .chat__head-text small { color: rgba(246, 241, 233, 0.6); font-size: 0.68rem; letter-spacing: 0.02em; }
  .chat__close { background: none; border: none; color: rgba(246, 241, 233, 0.7); cursor: pointer; padding: 4px; border-radius: 6px; }
  .chat__close:hover { color: #fff; }

  .chat__log { flex: 1; overflow-y: auto; padding: 1.1rem 1rem 0.5rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .chat__log::-webkit-scrollbar { width: 6px; }
  .chat__log::-webkit-scrollbar-thumb { background: var(--line); border-radius: 3px; }

  .chat__msg { max-width: 86%; padding: 0.7rem 0.9rem; border-radius: 14px; font-size: 0.9rem; line-height: 1.55; }
  .chat__msg--bot { align-self: flex-start; background: #fff; border: 1px solid var(--line-soft); border-bottom-left-radius: 5px; color: var(--ink-soft); }
  .chat__msg--user { align-self: flex-end; background: var(--gold); color: #fff; border-bottom-right-radius: 5px; }
  .chat__msg a { color: var(--gold-deep); text-decoration: underline; }
  .chat__msg--user a { color: #fff; }

  .chat__typing { align-self: flex-start; display: inline-flex; gap: 4px; padding: 0.8rem 0.9rem; background: #fff; border: 1px solid var(--line-soft); border-radius: 14px; border-bottom-left-radius: 5px; }
  .chat__typing span { width: 6px; height: 6px; border-radius: 50%; background: var(--gold-soft); animation: chatdot 1s infinite ease-in-out; }
  .chat__typing span:nth-child(2) { animation-delay: 0.15s; }
  .chat__typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes chatdot { 0%, 60%, 100% { opacity: 0.3; transform: translateY(0); } 30% { opacity: 1; transform: translateY(-3px); } }

  .chat__suggestions { display: flex; flex-wrap: wrap; gap: 0.4rem; padding: 0.4rem 1rem 0.7rem; }
  .chat__chip {
    background: transparent; border: 1px solid var(--line); color: var(--gold-deep);
    border-radius: 999px; padding: 0.4rem 0.8rem; font-size: 0.76rem; cursor: pointer;
    font-family: var(--sans); transition: background 0.25s var(--ease), color 0.25s var(--ease);
  }
  .chat__chip:hover { background: var(--gold); color: #fff; border-color: var(--gold); }

  .chat__form { display: flex; align-items: center; gap: 0.5rem; padding: 0.7rem 0.8rem; border-top: 1px solid var(--line-soft); background: var(--cream-2); }
  .chat__input { flex: 1; border: 1px solid var(--line); background: #fff; border-radius: 999px; padding: 0.65rem 1rem; font-size: 0.88rem; font-family: var(--sans); color: var(--ink); outline: none; }
  .chat__input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184, 148, 77, 0.15); }
  .chat__send { flex: none; width: 42px; height: 42px; border-radius: 50%; border: none; background: var(--gold); color: #fff; cursor: pointer; display: grid; place-items: center; transition: background 0.25s var(--ease); }
  .chat__send:hover { background: var(--gold-deep); }
  .chat__disclaimer { margin: 0; padding: 0 1rem 0.7rem; font-size: 0.64rem; color: var(--muted); text-align: center; background: var(--cream-2); }

  @media (max-width: 460px) {
    .chat__launcher-label { display: none; }
    .chat__launcher { padding: 0.85rem; }
    .chat__panel { width: min(94vw, 380px); height: min(78vh, 560px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .chat__panel, .chat__launcher { transition: none; }
    .chat__typing span { animation: none; }
  }
</style>

<script define:vars={{ data }}>
  (() => {
    const root = document.querySelector('[data-chat]');
    if (!root) return;
    const openBtn = root.querySelector('[data-chat-open]');
    const closeBtn = root.querySelector('[data-chat-close]');
    const panel = root.querySelector('[data-chat-panel]');
    const log = root.querySelector('[data-chat-log]');
    const sugg = root.querySelector('[data-chat-suggestions]');
    const form = root.querySelector('[data-chat-form]');
    const input = root.querySelector('[data-chat-input]');
    const ui = data.ui;
    const kb = data.kb;
    const storeKey = 'in2chat:' + data.lang;

    const normalize = (s) =>
      (s || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9\s]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

    // Two tokens match if equal or one is a stem of the other (plurals, endings).
    const stemMatch = (a, b) => {
      if (a === b) return true;
      const [s, l] = a.length <= b.length ? [a, b] : [b, a];
      return s.length >= 4 && l.startsWith(s);
    };

    // Generic words (EN/PL/RO) that carry no intent — excluded from token scoring.
    const STOP = new Set(
      ('the and for with you your our does what how about tell please would could need want ' +
       'have has can are was were will this that they them from into your yours' +
       'jak czy dla jest sie tak nie mam chce wam nas was oraz jakie jaki jaka ktore prosze ' +
       'ce cum despre pentru este sunt imi mie vreau doresc care voi vostru vreme').split(/\s+/)
    );
    const words = (s) => normalize(s).split(' ').filter((w) => w.length >= 3 && !STOP.has(w));

    // Precompute normalized keyword phrases + a token set per entry.
    const index = kb.map((entry) => {
      const phrases = [];
      const tokens = new Set();
      for (const kw of entry.keywords) {
        const nk = normalize(kw);
        if (!nk) continue;
        phrases.push(nk);
        words(nk).forEach((w) => tokens.add(w));
      }
      const qTokens = new Set(words(entry.question));
      qTokens.forEach((w) => tokens.add(w));
      return { entry, phrases, tokens: [...tokens], qTokens };
    });

    function bestMatch(query) {
      const nq = ' ' + normalize(query) + ' ';
      const uTokens = words(query);
      let best = null;
      let bestScore = 0;
      for (const item of index) {
        let score = 0;
        // Whole-phrase keyword matches (strongest signal for intent).
        for (const nk of item.phrases) {
          if (nq.includes(' ' + nk + ' ')) {
            const words = nk.split(' ').length;
            score += 2 + (words - 1) * 3 + nk.length * 0.05;
          }
        }
        // Token-level matches with light stemming (handles plurals / phrasing).
        for (const ut of uTokens) {
          if (item.tokens.some((et) => stemMatch(ut, et))) {
            score += item.qTokens.has(ut) ? 1.4 : 1;
          }
        }
        if (score > bestScore) { bestScore = score; best = item.entry; }
      }
      return bestScore >= 2 ? best : null;
    }

    // Linkify emails, phone numbers and the website.
    const escapeHtml = (s) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    function linkify(text) {
      let html = escapeHtml(text);
      html = html.replace(/([a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,})/gi, '<a href="mailto:$1">$1</a>');
      html = html.replace(/(\+48\s?\d{3}\s?\d{3}\s?\d{3})/g, (m) => `<a href="tel:${m.replace(/\s/g, '')}">${m}</a>`);
      html = html.replace(/\b(www\.in2scentedart\.com)\b/g, '<a href="https://$1" target="_blank" rel="noopener">$1</a>');
      return html;
    }

    let history = [];
    try { history = JSON.parse(sessionStorage.getItem(storeKey) || '[]'); } catch (e) { history = []; }

    function persist() {
      try { sessionStorage.setItem(storeKey, JSON.stringify(history.slice(-40))); } catch (e) {}
    }

    // Scroll the log so a message is either fully at the bottom, or aligned to the
    // top of the viewport (used for long bot answers so the reply reads from its start).
    function scrollToShow(el, align) {
      if (align === 'top') {
        const top = el.getBoundingClientRect().top - log.getBoundingClientRect().top + log.scrollTop;
        log.scrollTop = Math.max(0, top - 8);
      } else {
        log.scrollTop = log.scrollHeight;
      }
    }

    function appendMessage(role, text, save = true) {
      const el = document.createElement('div');
      el.className = 'chat__msg chat__msg--' + role;
      el.innerHTML = linkify(text);
      log.appendChild(el);
      if (save) { history.push({ role, text }); persist(); }
      return el;
    }

    function showTyping() {
      const el = document.createElement('div');
      el.className = 'chat__typing';
      el.setAttribute('data-typing', '');
      el.innerHTML = '<span></span><span></span><span></span>';
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
      return el;
    }

    function renderSuggestions() {
      sugg.innerHTML = '';
      (ui.suggestions || []).forEach((s) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'chat__chip';
        chip.textContent = s.label;
        chip.addEventListener('click', () => handleUser(s.label, s.query));
        sugg.appendChild(chip);
      });
    }

    function respond(query) {
      const typing = showTyping();
      const match = bestMatch(query);
      window.setTimeout(() => {
        typing.remove();
        const el = appendMessage('bot', match ? match.answer : ui.fallback);
        // Align the reply's top to the top of the log so it reads from the beginning.
        scrollToShow(el, 'top');
      }, 320);
    }

    function handleUser(displayText, query) {
      const el = appendMessage('user', displayText);
      scrollToShow(el, 'bottom');
      respond(query || displayText);
    }

    // Restore or greet.
    if (history.length) {
      history.forEach((m) => appendMessage(m.role, m.text, false));
    } else {
      appendMessage('bot', ui.greeting);
    }
    log.scrollTop = log.scrollHeight;
    renderSuggestions();

    // Open / close.
    function openChat() {
      panel.hidden = false;
      requestAnimationFrame(() => root.classList.add('is-open'));
      openBtn.setAttribute('aria-expanded', 'true');
      window.setTimeout(() => input && input.focus(), 200);
    }
    function closeChat() {
      root.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      window.setTimeout(() => { panel.hidden = true; }, 300);
      openBtn.focus();
    }
    openBtn.addEventListener('click', openChat);
    closeBtn.addEventListener('click', closeChat);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && root.classList.contains('is-open')) closeChat();
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const val = (input.value || '').trim();
      if (!val) return;
      input.value = '';
      handleUser(val, val);
    });
  })();
</script>
